# ==============================================================================
# .NET 9 Clean Architecture Professional .gitignore
# ==============================================================================

# ==============================================================================
# 1. Build Artifacts
# ==============================================================================
# Ignore all bin and obj folders at any level
[Bb]in/
[Oo]bj/

# Ignore explicit build output files (just in case they fall outside bin/obj)
*.dll
*.pdb
*.exe
*.o
*.obj
*.so
*.dylib
*.a
*.lib

# ==============================================================================
# 2. IDE & Editor Files
# ==============================================================================
# Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.userprefs
*.ide
*.docstates
*.vshost.*

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains Rider / ReSharper
.idea/
*.sln.iml
*.[Rr]e[Ss]harper
*.DotSettings.user

# ==============================================================================
# 3. Testing Artifacts
# ==============================================================================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
[Tt]est[Rr]esult.*
*.coverage
*.coveragexml
coverage/
CoverageReport/

# ==============================================================================
# 4. NuGet Artifacts
# ==============================================================================
# NuGet Packages
*.nupkg
*.snupkg
# The packages folder can be ignored because of PackageReference
[Pp]ackages/
# project.lock.json and other generated files
project.lock.json
project.assets.json
.nuget/

# ==============================================================================
# 5. Local Environment & Configuration Files
# ==============================================================================
# Ignore environment files
.env
.env.*
!.env.example
!.env.template

# Ignore local configuration overrides
appsettings.Local.json
appsettings.Development.json
secrets.json

# ==============================================================================
# 6. Operating System Files
# ==============================================================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.directory

# ==============================================================================
# 7. Temporary & Generated Files
# ==============================================================================
# Logs
[Ll]ogs/
*.log
*.err

# Backups and temp files
*.bak
*.cache
*.tmp
*.temp
*.swp
*.~*
~*.*

# ==============================================================================
# 8. AI Development Tool Temporary Folders
# ==============================================================================
# Claude / Anthropic
.claude/
.claude-cache/

# Gemini / Google
.gemini/
.gemini-cache/

# Generic AI caches
.ai-cache/
.ai/
.copilot/

# ==============================================================================
# 9. Tracked Files (Exceptions)
# ==============================================================================
# Ensure that important files are not accidentally ignored
!*.sln
!*.csproj
!*.cs
!*.md
!*.json
!*.yaml
!*.yml
!*.xml
!*.html
!*.css
!*.js
!*.ts
!*.sh
!*.bat
!*.ps1
!docs/
!README.md
!CHANGELOG.md
!LICENSE
